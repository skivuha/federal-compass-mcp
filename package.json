{
  "name": "federal-compass-mcp",
  "version": "0.1.6",
  "description": "Your AI compass from private sector to federal career — MCP server for USAJobs API",
  "mcpName": "io.github.skivuha/federal-compass-mcp",
  "keywords": [
    "mcp",
    "mcp-server",
    "usajobs",
    "federal",
    "government",
    "career",
    "jobs",
    "claude",
    "ai",
    "gs-pay",
    "security-clearance"
  ],
  "type": "module",
  "bin": {
    "federal-compass-mcp": "./build/src/index.js"
  },
  "main": "./build/src/index.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node build/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "bundle": "vite build",
    "clean": "rm -rf build"
  },
  "files": [
    "build/src",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skivuha/federal-compass-mcp.git"
  },
  "homepage": "https://github.com/skivuha/federal-compass-mcp#readme",
  "bugs": {
    "url": "https://github.com/skivuha/federal-compass-mcp/issues"
  },
  "author": "Igor Danylov",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "axios": "^1.7.0",
    "debug": "^4.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/debug": "^4.1.0",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.4"
  }
}
